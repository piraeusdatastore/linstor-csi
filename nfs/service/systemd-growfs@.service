[Unit]
Description=Grow File System on %f
Documentation=man:systemd-growfs@.service(8)

DefaultDependencies=no
# Usually this would bind to the mount target, we don't need that for our purposes
BindsTo=
After=
Conflicts=shutdown.target
Before=shutdown.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/lib/systemd/systemd-growfs %f
TimeoutSec=infinity

BindPaths=/host/dev:/dev
